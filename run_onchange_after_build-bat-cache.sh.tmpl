#!/bin/sh

# Rebuild when either vendored Tokyo Night theme changes.
# storm: {{ include "private_dot_config/bat/themes/tokyonight_storm.tmTheme" | sha256sum }}
# day: {{ include "private_dot_config/bat/themes/tokyonight_day.tmTheme" | sha256sum }}

if command -v bat >/dev/null 2>&1; then
  bat cache --build
fi
